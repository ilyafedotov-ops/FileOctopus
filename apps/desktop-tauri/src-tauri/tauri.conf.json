{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FileOctopus",
  "version": "0.1.7",
  "identifier": "com.fileoctopus.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm -w build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FileOctopus",
        "width": 1280,
        "height": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: ipc: asset: http://ipc.localhost; img-src 'self' data: tauri: asset:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
