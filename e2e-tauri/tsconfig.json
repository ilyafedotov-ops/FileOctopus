{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "@wdio/globals/types", "@wdio/mocha-framework"],
    "allowImportingTsExtensions": false
  },
  "include": ["wdio.conf.ts", "specs/**/*.ts"]
}
