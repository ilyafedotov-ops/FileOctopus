{
  "name": "fileoctopus",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "bootstrap": "bash scripts/bootstrap.sh",
    "dev": "pnpm --filter @fileoctopus/ts-api build && pnpm --filter @fileoctopus/ui build && pnpm --filter @fileoctopus/frontend build && pnpm --filter @fileoctopus/desktop-tauri tauri dev",
    "build": "pnpm -r --sort --if-present build",
    "typecheck": "pnpm -r --sort --if-present typecheck",
    "lint": "eslint \"{apps,packages}/**/*.{ts,tsx}\"",
    "format:check": "prettier --check package.json pnpm-workspace.yaml README.md \".github/**/*.{md,yml,yaml}\" \"docs/**/*.md\" \"apps/**/*.{ts,tsx,css,json,md}\" \"packages/**/*.{ts,tsx,json,md}\"",
    "format": "prettier --write package.json pnpm-workspace.yaml README.md \".github/**/*.{md,yml,yaml}\" \"docs/**/*.md\" \"apps/**/*.{ts,tsx,css,json,md}\" \"packages/**/*.{ts,tsx,json,md}\"",
    "test": "pnpm -r --sort --if-present test",
    "test:backend:rc": "cargo fmt --all --check && cargo check --workspace && cargo test --workspace && cargo clippy --workspace --all-targets -- -D warnings",
    "test:frontend:rc": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "rc:validate": "pnpm test:backend:rc && pnpm test:frontend:rc",
    "tauri:build": "pnpm --filter @fileoctopus/desktop-tauri tauri build",
    "rust:check": "cargo check --workspace",
    "rust:test": "cargo test --workspace",
    "rust:fmt": "cargo fmt --all --check",
    "rust:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "pnpm typecheck && pnpm format:check && cargo fmt --all --check"
  },
  "lint-staged": {
    "*.{ts,tsx,css,json,md}": "prettier --write",
    "*.{ts,tsx}": "eslint --fix",
    "*.rs": "cargo fmt --"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "lint-staged": "^16.1.2",
    "prettier": "^3.7.4",
    "simple-git-hooks": "^2.13.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.14"
  }
}
