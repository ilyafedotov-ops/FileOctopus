{
  "name": "@fileoctopus/ui",
  "private": true,
  "version": "0.1.6",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.tsx",
        "import": "./src/index.tsx"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components.css": {
      "development": "./src/components.css",
      "default": "./dist/components.css"
    },
    "./tokens.css": {
      "development": "./src/tokens.css",
      "default": "./dist/tokens.css"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean-package.mjs && tsc -p tsconfig.json && node ../../scripts/fix-package-esm.mjs && node ../../scripts/copy-package-assets.mjs src/components.css:dist/components.css src/tokens.css:dist/tokens.css",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run tests --environment jsdom"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "jsdom": "^25.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "lucide-react": "^1.16.0"
  }
}
