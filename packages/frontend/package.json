    "@xterm/xterm": "^6.0.0"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "jsdom": "^25.0.1",
    "typescript": "^5.8.3",
    "vitest": "^4.0.14"
  }
