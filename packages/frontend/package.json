{
  "name": "@fileoctopus/frontend",
  "private": true,
  "version": "0.1.6",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.tsx",
        "import": "./src/index.tsx"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles/app.css": {
      "development": "./src/styles/app.css",
      "default": "./dist/styles/app.css"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean-package.mjs && tsc -p tsconfig.json && node ../../scripts/fix-package-esm.mjs && node ../../scripts/copy-package-assets.mjs src/styles:dist/styles",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.0",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/lang-rust": "^6.0.1",
    "@codemirror/lang-sql": "^6.8.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.4.2",
    "@codemirror/search": "^6.5.6",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.0",
    "@fileoctopus/ts-api": "workspace:*",
    "@fileoctopus/ui": "workspace:*",
    "@lezer/highlight": "^1.2.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "pdfjs-dist": "^5.7.284"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "jsdom": "^25.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
